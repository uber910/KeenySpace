KEENYSPACE_DB__URL=postgresql+asyncpg://keenyspace:devpw@localhost:5432/keenyspace
KEENYSPACE_FS__ROOT=/var/lib/keenyspace
KEENYSPACE_AUTH__DEV_TOKEN=devtoken-replace-me
KEENYSPACE_AUTH__MULTI_WORKER=false
KEENYSPACE_WAL__MAX_ENTRY_BYTES=262144
KEENYSPACE_SERVER__HOST=0.0.0.0
KEENYSPACE_SERVER__PORT=8000
KEENYSPACE_SERVER__LOG_LEVEL=INFO
KEENYSPACE_AUTO_MIGRATE=false
